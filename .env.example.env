# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional: Model choice (default: claude-sonnet-4-20250514)
# MODEL=claude-sonnet-4-20250514

# Optional: Max response tokens (default: 1024)
# MAX_TOKENS=1024

# Optional: Comma-separated phone numbers to allow (with country code, no +)
# Leave empty to allow all incoming messages
# ALLOWED_NUMBERS=15551234567,447700900000